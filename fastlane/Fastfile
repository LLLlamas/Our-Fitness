# Mac-less workflow.
# Signing assets live in an encrypted fastlane match repository.
# CI syncs them into a temporary keychain instead of creating certificates every run.
#
# Required env (set as GitHub secrets, exported by the workflow):
#   APPLE_TEAM_ID
#   APP_STORE_CONNECT_API_KEY_ID
#   APP_STORE_CONNECT_API_ISSUER_ID
#   APP_STORE_CONNECT_API_KEY_P8   (full .p8 contents incl. BEGIN/END lines)
#   KEYCHAIN_PASSWORD              (any random string; temp keychain on the runner)
#   MATCH_GIT_URL                  (private encrypted match repo)
#   MATCH_PASSWORD                 (encryption passphrase for match repo)
#   MATCH_GIT_BASIC_AUTHORIZATION  (base64 "github-user:token" for match repo)

default_platform(:ios)

SCHEME       = "OurFitness"
PROJECT      = "OurFitness.xcodeproj"
BUNDLE_ID    = "com.ourfitness.app"
PROFILE_NAME = "OurFitness AppStore"
# Widget extension (Live Sessions Live Activity) — a second signed binary embedded
# in the app. Its profile name must match PROVISIONING_PROFILE_SPECIFIER for the
# OurFitnessWidgets target in project.yml. Profile base64 lives in the
# APPSTORE_WIDGET_PROFILE_BASE64 secret. See docs/live-activity-setup.md.
WIDGET_BUNDLE_ID    = "com.ourfitness.app.widgets"
WIDGET_PROFILE_NAME = "OurFitnessWidgets AppStore"
KEYCHAIN     = "ourfitness-ci.keychain-db"
OUTPUT_DIR   = "build"

# ─────────────────────────────────────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────────────────────────────────────

def api_key_object
  app_store_connect_api_key(
    key_id:       ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id:    ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
    key_content:  ENV.fetch("APP_STORE_CONNECT_API_KEY_P8"),
    in_house:     false,
    is_key_content_base64: false,
  )
end

def ensure_keychain
  password = ENV.fetch("KEYCHAIN_PASSWORD")
  create_keychain(
    name: KEYCHAIN,
    password: password,
    default_keychain: true,
    unlock: true,
    timeout: 3600,
    lock_when_sleeps: false,
  )
end

def match_readonly?
  ENV.fetch("MATCH_READONLY", "true") != "false"
end

def env_or_default(name, fallback)
  value = ENV[name].to_s.strip
  value.empty? ? fallback : value
end

# Install one manually-generated provisioning profile (decoded from a base64
# secret) into Xcode's profiles dir, keyed by the UUID inside the profile so the
# provisioning subsystem indexes it. `expect_healthkit:` runs the app-only
# entitlement diagnostic; the widget profile legitimately carries ZERO managed
# capabilities, so that check is skipped for it.
def install_one_profile(profile_b64, label, expect_healthkit: false)
  UI.user_error!(
    "#{label} profile base64 is empty. Generate the App Store profile in " \
    "developer.apple.com → Profiles, base64-encode the .mobileprovision, and " \
    "save it as the matching GitHub repository secret."
  ) if profile_b64.empty?

  dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
  FileUtils.mkdir_p(dir)

  raw = Base64.decode64(profile_b64)
  plist = raw[/<\?xml.*<\/plist>/m] ||
    UI.user_error!("Could not extract plist payload from the #{label} .mobileprovision blob.")
  uuid = plist[/<key>UUID<\/key>\s*<string>([0-9A-Fa-f-]+)<\/string>/, 1] ||
    UI.user_error!("Could not find UUID inside the #{label} provisioning profile.")
  name = plist[/<key>Name<\/key>\s*<string>([^<]+)<\/string>/, 1] || "unknown"

  dest = File.join(dir, "#{uuid}.mobileprovision")
  File.binwrite(dest, raw)
  UI.success("Installed #{label} profile '#{name}' (#{uuid}) → #{dest} (#{raw.bytesize} bytes)")

  # Extract and log the certificate SHA1(s) embedded in this profile so a
  # cert-mismatch failure at archive time can be diagnosed immediately here
  # instead of 10 minutes later. Compare against the cert match just installed:
  #   security find-identity -v -p codesigning
  require "openssl"
  cert_shas = []
  raw.scan(/-----BEGIN CERTIFICATE-----.*?-----END CERTIFICATE-----/m) do |pem|
    cert = OpenSSL::X509::Certificate.new(pem) rescue nil
    next unless cert
    sha1 = OpenSSL::Digest::SHA1.new(cert.to_der).hexdigest.upcase.scan(/../).join(":")
    cert_shas << "#{cert.subject.to_s.scan(/CN=([^,\/]+)/).flatten.first || "unknown"} [#{sha1[0..29]}…]"
  end
  if cert_shas.empty?
    UI.warning("#{label} profile: could not extract embedded certificates (unexpected format).")
  else
    UI.message("#{label} profile embedded cert(s): #{cert_shas.join(', ')}")
  end

  entitlements = plist.scan(/<key>(com\.apple\.developer\.[a-zA-Z0-9._-]+)<\/key>/).flatten.uniq.sort
  unless expect_healthkit
    # Widget has no managed capabilities — zero entitlements is correct here.
    UI.message("#{label} profile entitlements: #{entitlements.empty? ? '(none — expected for the widget)' : entitlements.join(', ')}")
    return
  end

  if entitlements.empty?
    UI.error("#{label} profile declares ZERO com.apple.developer.* entitlements. " \
             "This means the profile was generated without any capabilities " \
             "attached. Regenerate at developer.apple.com → Profiles → +.")
  else
    UI.message("#{label} profile entitlements (com.apple.developer.*):")
    entitlements.each { |k| UI.message("  • #{k}") }
    missing = %w[com.apple.developer.healthkit
                 com.apple.developer.healthkit.background-delivery] - entitlements
    if missing.any?
      UI.error("#{label} profile is MISSING these expected entitlements: #{missing.join(', ')}. " \
               "Signing will strip them from the IPA. Regenerate the profile in " \
               "developer.apple.com (delete the old one first, then create a new " \
               "one — Edit/Save on an existing profile does NOT refresh capabilities).")
    end
  end
end

def match_options(api_key)
  options = {
    type: "appstore",
    api_key: api_key,
    app_identifier: BUNDLE_ID,
    team_id: ENV.fetch("APPLE_TEAM_ID"),
    git_url: ENV.fetch("MATCH_GIT_URL"),
    git_branch: env_or_default("MATCH_GIT_BRANCH", "main"),
    git_full_name: env_or_default("MATCH_GIT_FULL_NAME", "Our-Fitness CI"),
    git_user_email: env_or_default("MATCH_GIT_USER_EMAIL", "ci@ourfitness.local"),
    readonly: match_readonly?,
    keychain_name: KEYCHAIN,
    keychain_password: ENV.fetch("KEYCHAIN_PASSWORD"),
    profile_name: PROFILE_NAME,
    # Skip profile management entirely. The profile is installed in a separate
    # step (install_appstore_profile) from the APPSTORE_PROFILE_BASE64 secret.
    # See `install_appstore_profile` lane for full context. match's role here
    # is reduced to syncing the Apple Distribution certificate.
    skip_provisioning_profiles: true,
    # DO NOT pass `force: true`. Apple removed the App Store Connect API
    # endpoint that match used to attach capabilities to regenerated
    # profiles (May 2025, ASC API v3.8.0). Forcing match to regenerate
    # produces a profile WITHOUT HealthKit / Background Delivery /
    # Sign-in-with-Apple / Push, even when the App ID has them enabled.
    # See https://docs.fastlane.tools/actions/match/#managed-capabilities.
    # The HealthKit-capable provisioning profile lives in the certs repo
    # as a manually-generated artifact (see .github/workflows/import-profile.yml).
    # Refresh mode (`MATCH_READONLY=false`) is still useful for cert
    # rotation and importing manually-generated profiles — it just
    # doesn't auto-regenerate the profile anymore.
  }

  basic_auth = ENV["MATCH_GIT_BASIC_AUTHORIZATION"].to_s.strip
  options[:git_basic_authorization] = basic_auth unless basic_auth.empty?

  options
end

# ─────────────────────────────────────────────────────────────────────────────
# Lanes
# ─────────────────────────────────────────────────────────────────────────────

platform :ios do

  desc "Run unit tests on an iOS simulator. No signing needed."
  lane :tests do
    scan(
      project: PROJECT,
      scheme: SCHEME,
      device: "iPhone 17",
      code_coverage: true,
      clean: true,
      output_directory: "#{OUTPUT_DIR}/test_output",
      result_bundle: true,
      xcargs: "ASSETCATALOG_COMPILER_SKIP_APP_STORE_DEPLOYMENT=YES",
    )
  end

  desc "Build the app without signing — just confirms it compiles on CI."
  lane :compile do
    xcodebuild(
      project: PROJECT,
      scheme: SCHEME,
      destination: "platform=iOS Simulator,name=iPhone 17",
      configuration: "Debug",
      xcargs: "CODE_SIGNING_ALLOWED=NO ASSETCATALOG_COMPILER_SKIP_APP_STORE_DEPLOYMENT=YES build",
    )
  end

  desc "Bootstrap or refresh TestFlight signing assets in match. No build/archive."
  lane :sync_signing do
    api_key = api_key_object
    ensure_keychain

    match(**match_options(api_key))
  end

  desc "Install a manually-generated provisioning profile from the " \
       "APPSTORE_PROFILE_BASE64 secret into Xcode's profiles directory. " \
       "Run this as a step inside the TestFlight job so the build can pick " \
       "the profile up by name. The profile must be generated by hand in the " \
       "Apple Developer portal — fastlane match cannot generate capability- " \
       "bearing profiles since Apple removed the API in May 2025."
  lane :install_appstore_profile do
    # Apple's Xcode finds profiles by UUID, not filename — install_one_profile
    # writes each under its UUID. Install BOTH embedded binaries' profiles: the
    # app (HealthKit/Background-Delivery capabilities expected) and the widget
    # extension (no managed capabilities). See docs/live-activity-setup.md.
    install_one_profile(
      ENV.fetch("APPSTORE_PROFILE_BASE64", "").to_s.strip,
      "app (#{BUNDLE_ID})", expect_healthkit: true
    )
    install_one_profile(
      ENV.fetch("APPSTORE_WIDGET_PROFILE_BASE64", "").to_s.strip,
      "widget (#{WIDGET_BUNDLE_ID})", expect_healthkit: false
    )
  end

  desc "Ship a build to TestFlight. Syncs signing with match, archives, and uploads."
  lane :beta do
    api_key = api_key_object
    ensure_keychain

    # match stores the Apple Distribution certificate private key and profile
    # in encrypted git storage. Normal CI runs are read-only so they cannot
    # consume Apple's limited distribution certificate slots.
    match(**match_options(api_key))

    # Bump build number to the GitHub Actions run number (or +1 of latest).
    run_number = ENV["GITHUB_RUN_NUMBER"]
    if run_number
      increment_build_number(
        xcodeproj: PROJECT,
        build_number: run_number,
      )
    else
      latest = latest_testflight_build_number(
        api_key: api_key, app_identifier: BUNDLE_ID,
      )
      increment_build_number(xcodeproj: PROJECT, build_number: latest + 1)
    end

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "#{OUTPUT_DIR}/ipa",
      output_name: "OurFitness.ipa",
      clean: true,
      include_symbols: true,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          BUNDLE_ID        => PROFILE_NAME,
          WIDGET_BUNDLE_ID => WIDGET_PROFILE_NAME,
        },
      },
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true,                 # we'll choose when to push to reviewers
      ipa: "#{OUTPUT_DIR}/ipa/OurFitness.ipa",
      changelog: ENV["CHANGELOG"] || "Internal build #{run_number || Time.now.to_i}",
    )
  end

  after_all do |lane|
    UI.success("✓ #{lane} complete")
  end

  error do |lane, exception|
    UI.error("✗ #{lane} failed: #{exception.message}")
  end
end
